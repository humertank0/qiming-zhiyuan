# 启明志愿 配置文件
# 复制此文件为 .env，填入你的 API Key

# ── 方式一：手动指定 OpenAI-compatible 上游（推荐）──
# 可填写 DeepSeek / 通义千问 / 智谱 / Moonshot / OpenAI / cliproxyapi / sub2api / 自建代理等兼容地址
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
# DeepSeek 可选模型：deepseek-chat（通用）/ deepseek-v4-pro（最强）/ deepseek-v4-flash（性价比）

# ── 方式二：用 LLM_PROVIDER 快捷切换 ──
# （注意：用 LLM_PROVIDER 时删掉上面 LLM_MODEL 那行，否则 LLM_MODEL 会覆盖默认模型）
# LLM_PROVIDER=deepseek   # DeepSeek
# LLM_PROVIDER=qwen       # 通义千问
# LLM_PROVIDER=glm        # 智谱 GLM-4
# LLM_PROVIDER=moonshot   # Moonshot
# LLM_PROVIDER=openai     # OpenAI
# LLM_PROVIDER=ollama     # 本地模型（免费离线）

# ── Web 服务配置 ──
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── 功能开关 ──
ENABLE_SEARCH=true
MAX_HISTORY_MESSAGES=20
WEB_ENABLE_BACKEND_LLM=true
WEB_ENABLE_BYOK_DIRECT=true

# 初版不开放“用户 Key 经启明志愿后端转发”的模式。
# 用户自带 Key 模式默认由浏览器直连 provider，Key 不发送到启明志愿后端。
ALLOW_BYOK_PROXY=false

# 生产环境如需限制跨域，可填写逗号分隔的允许来源。
# 本地同源访问不需要配置。
# WEB_CORS_ORIGINS=https://your-domain.example
