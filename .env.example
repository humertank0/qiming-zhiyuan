# 启明志愿 Debian/Web 服务配置
# 复制此文件为 .env，填入后端模型服务 Key。不要提交 .env。

# ── OpenAI-compatible 上游模型 ──
# 可填写 DeepSeek / 通义千问 / 智谱 / Moonshot / OpenAI / cliproxyapi / sub2api / 自建代理等兼容地址
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 也可以用 LLM_PROVIDER 快捷切换；如果同时设置 LLM_MODEL，LLM_MODEL 会覆盖默认模型。
# LLM_PROVIDER=deepseek
# LLM_PROVIDER=qwen
# LLM_PROVIDER=glm
# LLM_PROVIDER=moonshot
# LLM_PROVIDER=openai

# ── Web 服务配置 ──
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── 功能开关 ──
ENABLE_SEARCH=true
MAX_HISTORY_MESSAGES=20
WEB_MAX_SESSIONS=3000
WEB_SESSION_TTL_SECONDS=7200
BACKEND_LLM_CONCURRENCY=80
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=1200
WEB_ENABLE_BACKEND_LLM=true

# ── 搜索配置 ──
# 搜索引擎只用于发现候选网页；真正进入模型前，会按来源可信度和问题相关性过滤。
SEARCH_TRUSTED_DOMAINS=moe.gov.cn,chsi.com.cn,gaokao.chsi.com.cn,edu.cn,gov.cn,eol.cn,gaokao.cn
SEARCH_MIN_RELEVANCE=6
SEARCH_MAX_RESULTS=5
SEARCH_MAX_QUERIES=4
SEARCH_TIMEOUT_SECONDS=5
SEARCH_MAX_PAGE_BYTES=300000

# ── 安全与限流 ──
WEB_RATE_LIMIT_ENABLED=true
WEB_CHAT_RATE_LIMIT_PER_MINUTE=6
WEB_CHAT_RATE_LIMIT_PER_HOUR=60
WEB_SESSION_RATE_LIMIT_PER_HOUR=30
WEB_RESET_RATE_LIMIT_PER_MINUTE=10
MAX_MESSAGE_CHARS=1200
MAX_ASSISTANT_REPLY_CHARS=6000
MAX_PENDING_TURNS_PER_SESSION=3
PENDING_TURN_TTL_SECONDS=600
SAFETY_ENABLED=true

# 只有在可信 Nginx/Cloudflare 反代后面部署时才开启，否则不要信任 X-Forwarded-For。
TRUST_PROXY_HEADERS=false

# 服务器部署默认不建议开启 BYOK 浏览器直连。
# 如果开启，用户 Key 会在用户自己的浏览器环境里使用，启明志愿后端不接触该 Key。
WEB_ENABLE_BYOK_DIRECT=false
ALLOW_BYOK_PROXY=false

# 生产环境如需限制跨域，可填写逗号分隔的允许来源。
# WEB_CORS_ORIGINS=https://your-domain.example
